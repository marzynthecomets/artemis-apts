{
  "manifest_version": 3,
  "name": "Apartment Tracker",
  "version": "1.1",
  "description": "Capture apartment listings while browsing and save them to your tracker.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Save this listing"
  }
}
